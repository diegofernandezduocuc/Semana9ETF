                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"clientePostman\",\n  \"correo\": \"cliente.postman@minimarket.local\",\n  \"password\": \"cliente123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
